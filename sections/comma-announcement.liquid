<div class="comma comma-announcement">
  <div class="comma-announcement__track">
    {% for block in section.blocks %}
      <span>{{ block.settings.text }}</span>
      <span aria-hidden="true">★</span>
    {% endfor %}
    {% comment %} duplicate for seamless loop {% endcomment %}
    {% for block in section.blocks %}
      <span>{{ block.settings.text }}</span>
      <span aria-hidden="true">★</span>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Comma Announcement",
  "tag": "section",
  "class": "comma-section-announcement",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Message", "default": "END OF SEASON SALE — UP TO 75% OFF LIVE NOW" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comma Announcement",
      "blocks": [{ "type": "message" }, { "type": "message" }, { "type": "message" }]
    }
  ]
}
{% endschema %}
